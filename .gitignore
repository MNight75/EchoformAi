# Ignore ephemeral runtime files
*.log
*.tmp
*.bak
*.pid
*.sock

# Ignore session history/transcripts
sessions/*.jsonl

# Ignore extensions (local plugins)
extensions/

# Ignore temp directories
tmp/
temp/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore node_modules
node_modules/

# Ignore config files with secrets (credentials, API keys, tokens)
openclaw.json
openclaw.json.*
*.json.bak
*.json.backup
credentials/
devices/
exec-approvals.json

# Ignore daily memory logs in all workspaces (too noisy)
workspace*/memory/*.md

# But keep tracked memory directories
!workspace*/memory/business/
!workspace*/memory/echoform/
!workspace*/memory/roy/
!workspace*/memory/social/

# Ignore agent .openclaw directories
workspace*/.openclaw/

# Ignore skills git repos (they're their own projects)
workspace/skills/*/.git/

# Ignore large binary/cache files
*.cache
cache/